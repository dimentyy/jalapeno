{
  "name": "whitelist-bypass-creator",
  "version": "0.1.7",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "whitelist.bypass.creator",
    "productName": "WhitelistBypass Creator",
    "directories": {
      "output": "../prebuilts"
    },
    "extraResources": [
      { "from": "../hooks/dc-creator-vk.js", "to": "hooks/dc-creator-vk.js" },
      { "from": "../hooks/dc-creator-telemost.js", "to": "hooks/dc-creator-telemost.js" },
      { "from": "../hooks/video-vk.js", "to": "hooks/video-vk.js" },
      { "from": "../hooks/video-telemost.js", "to": "hooks/video-telemost.js" }
    ],
    "mac": {
      "target": { "target": "dmg", "arch": "arm64" },
      "icon": "resources/icon.icns",
      "extraResources": [
        { "from": "../relay/relay-darwin-arm64", "to": "relay" }
      ]
    },
    "win": {
      "target": { "target": "portable", "arch": "x64" },
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "icon": "resources/icon.ico",
      "extraResources": [
        { "from": "../relay/relay-windows-x64.exe", "to": "relay.exe" }
      ]
    },
    "linux": {
      "target": { "target": "AppImage", "arch": "x64" },
      "icon": "resources/icon.png",
      "extraResources": [
        { "from": "../relay/relay-linux-x64", "to": "relay" }
      ]
    }
  }
}
